<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MatrixLab</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (Context.Session.GetString("auth") == "true")
    {
        <div class="topbar">
            <a href="/Logout" class="logout-btn">Terminar Sessão</a>
        </div>
    }

    @RenderBody()

    <footer class="footer">
        © @DateTime.Now.Year — MatrixLab
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
