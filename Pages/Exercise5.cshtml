@page
@model MatrixLab.Pages.Exercise5Model
@{
    ViewData["Title"] = "Exercício 5";
}

<div class="exercise-page">
    <a href="/" class="btn-back">← Voltar</a>
    <h2>Exercício 5</h2>
    <p class="exercise-desc">Duas matrizes 3×3 de inteiros — gerar e imprimir a matriz DIFERENÇA.</p>

    <form method="post">
        <div class="matrices-row">
            <div class="matrix-block">
                <h4>Matriz A</h4>
                <div class="matrix-grid" style="--cols: 3">
                    @for (int i = 0; i < 3; i++)
                    @for (int j = 0; j < 3; j++)
                    {
                        <input type="number" name="MatrixA[@i][@j]" value="@Model.MatrixA[i][j]" class="matrix-cell" />
                    }
                </div>
            </div>

            <div class="matrix-operator">−</div>

            <div class="matrix-block">
                <h4>Matriz B</h4>
                <div class="matrix-grid" style="--cols: 3">
                    @for (int i = 0; i < 3; i++)
                    @for (int j = 0; j < 3; j++)
                    {
                        <input type="number" name="MatrixB[@i][@j]" value="@Model.MatrixB[i][j]" class="matrix-cell" />
                    }
                </div>
            </div>
        </div>

        <div class="btn-group">
            <button type="submit" asp-page-handler="Generate" class="btn-secondary">🔀 Gerar Aleatório</button>
            <button type="submit" asp-page-handler="Execute" class="btn-primary">▶ Executar</button>
        </div>
    </form>

    @if (Model.Result != null)
    {
        <div class="result-box">
            <h3>Matriz DIFERENÇA</h3>
            <div class="matrix-grid" style="--cols: 3">
                @foreach (var val in Model.Result)
                {
                    <div class="matrix-cell result-cell">@val</div>
                }
            </div>
        </div>
    }
</div>
