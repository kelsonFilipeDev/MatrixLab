@page "/404"
@{
    ViewData["Title"] = "Página não encontrada";
}

<div class="error-page">
    <div class="error-code">404</div>
    <h2>Página não encontrada</h2>
    <p>A página que procuras não existe ou foi movida.</p>
    <a href="/" class="btn-primary" style="text-decoration:none; padding: 0.65rem 1.5rem; border-radius: 8px;">
        ← Voltar ao Dashboard
    </a>
</div>
