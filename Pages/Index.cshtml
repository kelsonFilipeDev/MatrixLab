@page
@model IndexModel
@{
    ViewData["Title"] = "MatrixLab";
}

<div class="dashboard">
    <div class="dashboard-header">
        <h1>MatrixLab</h1>
        <p>Exercícios de Matrizes em C#</p>
    </div>

    <div class="exercise-grid">
        @for (int i = 1; i <= 9; i++)
        {
            <a href="/Exercise@(i)" class="exercise-card">
                <span class="exercise-number">@i</span>
                <span class="exercise-label">Exercício @i</span>
            </a>
        }
    </div>
</div>
