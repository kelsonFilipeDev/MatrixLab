@page
@model MatrixLab.Pages.Exercise2Model
@{
    ViewData["Title"] = "Exercício 2";
}

<div class="exercise-page">
    <a href="/" class="btn-back">← Voltar</a>
    <h2>Exercício 2</h2>
    <p class="exercise-desc">Matriz 3×3 de inteiros — imprimir todos os elementos multiplicados por 2.</p>

    <form method="post">
        <div class="matrix-grid" style="--cols: 3">
            @for (int i = 0; i < 3; i++)
            @for (int j = 0; j < 3; j++)
            {
                <input type="number" name="Matrix[@i][@j]" value="@Model.Matrix[i][j]" class="matrix-cell" />
            }
        </div>
        <div class="btn-group">
            <button type="submit" asp-page-handler="Generate" class="btn-secondary">🔀 Gerar Aleatório</button>
            <button type="submit" asp-page-handler="Execute" class="btn-primary">▶ Executar</button>
        </div>
    </form>

    @if (Model.Result != null)
    {
        <div class="result-box">
            <h3>Resultado (×2)</h3>
            <div class="matrix-grid" style="--cols: 3">
                @foreach (var val in Model.Result)
                {
                    <div class="matrix-cell result-cell">@val</div>
                }
            </div>
        </div>
    }
</div>
